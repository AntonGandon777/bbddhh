    splashTitleStroke.Color = Color3.fromRGB(140, 25, 35) -- Matching Darker Crimson Red
    splashTitleStroke.Transparency = 1
    splashTitleStroke.Parent = splashTitle
    
    local splashSub = Instance.new(TextLabel)
    splashSub.Name = SplashSub
    splashSub.Size = UDim2.new(1, 0, 0, 36)
    splashSub.Position = UDim2.new(0.5, 0, 0.45, 40)
    splashSub.AnchorPoint = Vector2.new(0.5, 0.5)
    splashSub.BackgroundTransparency = 1
    splashSub.Text = p r o j e c t
    splashSub.TextColor3 = Color3.fromRGB(15, 15, 15)
    splashSub.TextSize = 30 -- Enlarged subtitle
    splashSub.Font = Enum.Font.SourceSansBold
    splashSub.TextTransparency = 1
    splashSub.ZIndex = 101
    splashSub.Parent = splashFrame
    
    local splashSubStroke = Instance.new(UIStroke)
