    -- Custom UI Mouse Lock Loop
    -- Bypasses shooter-game camera scripts that lock the default cursor to the center of the screen.
    local cursorConnection
    local function updateCursor()
        if screenGui.Enabled and mainFrame.Visible then
            UserInputService.MouseIconEnabled = true
            
            if not cursorConnection then
                cursorConnection = RunService.RenderSteppedConnect(function()
                    -- If the player is holding Right Mouse Button (standard shooter camera rotation),
                    -- allow the game's camera scripts to lockhide the mouse so they can rotate the view.
                    -- Otherwise, force Default behavior to unlock mouse to interact with the GUI.
                    if UserInputServiceIsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
                        -- Do nothing, let camera pan
                    else
                        if UserInputService.MouseBehavior ~= Enum.MouseBehavior.Default then
                            UserInputService.MouseBehavior = Enum.MouseBehavior.Default
                        end
                    end
                end)
            end
        else
            if cursorConnection then
                cursorConnectionDisconnect()
                cursorConnection = nil
            end
        end
    end
    
    screenGuiGetPropertyChangedSignal(Enabled)Connect(updateCursor)
    mainFrameGetPropertyChangedSignal(Visible)Connect(updateCursor)
    
    -- Initialize cursor state immediately
    updateCursor()
    
    -- Make the entire window draggable (still dragging the main outermost frame)
    makeDraggable(mainFrame)
    
    -- Toggle UI visibility keybind (Insert, RightShift, or RightControl)
    -- Bypasses the processed flag to make sure it opens even if the clientgame captures the shiftctrl key.
    local toggleConnection = UserInputService.InputBeganConnect(function(input, processed)
        local key = input.KeyCode
        if key == Enum.KeyCode.Insert or key == Enum.KeyCode.RightShift or key == Enum.KeyCode.RightControl then
            screenGui.Enabled = not screenGui.Enabled
        end
    end)
    
