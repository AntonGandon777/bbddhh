-- Clean up any existing instances of this GUI to prevent duplicates
local oldGui = nil
pcall(function()
    if gethui then
        oldGui = gethui():FindFirstChild("InventoryGui")
    else
        local playerGui = LocalPlayer:FindFirstChildOfClass("PlayerGui") or LocalPlayer:WaitForChild("PlayerGui", 5)
        oldGui = (CoreGui and CoreGui:FindFirstChild("InventoryGui")) or (playerGui and playerGui:FindFirstChild("InventoryGui"))
    end
    if oldGui then
        oldGui:Destroy()
    end
end)

-- Safe parenting to evade anti-cheat scans
local function getSafeParent()
    if gethui then
        local success, result = pcall(gethui)
        if success and result then
            return result
        end
    end
    if CoreGui then
        local success, result = pcall(function() return CoreGui end)
        if success and result then
            return result
        end
    end
    local playerGui = LocalPlayer:FindFirstChildOfClass("PlayerGui") or LocalPlayer:WaitForChild("PlayerGui", 10)
    if playerGui then
        return playerGui
    end
    return nil
end

-- Draggable implementation for the entire frame
local function makeDraggable(frame)
    local dragging = false
    local dragInput, dragStart, startPos
    
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    
    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging and dragStart and startPos then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

-- Helper to add spacing between letters
local function spaceOutLetters(text)
    if not text then return "" end
    local upperText = string.upper(tostring(text))
    local result = ""
    for i = 1, #upperText do
        local char = string.sub(upperText, i, i)
        result = result .. char .. (i < #upperText and " " or "")
    end
    return result
end

