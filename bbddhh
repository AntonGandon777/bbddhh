    splashSubStroke.Color = Color3.fromRGB(140, 25, 35)
    splashSubStroke.Transparency = 1
    splashSubStroke.Parent = splashSub
    
    -- Splash Animation Thread
    task.spawn(function()
        task.wait(0.3)
        -- Fade In text directly over game graphics
        local fadeInInfo = TweenInfo.new(1.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        TweenServiceCreate(splashTitle, fadeInInfo, {TextTransparency = 0})Play()
        TweenServiceCreate(splashTitleStroke, fadeInInfo, {Transparency = 0})Play()
        TweenServiceCreate(splashSub, fadeInInfo, {TextTransparency = 0})Play()
        TweenServiceCreate(splashSubStroke, fadeInInfo, {Transparency = 0})Play()
        
        task.wait(2.0) -- Stay visible
        
        -- Fade Out text
        local fadeOutInfo = TweenInfo.new(1.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        TweenServiceCreate(splashTitle, fadeOutInfo, {TextTransparency = 1})Play()
        TweenServiceCreate(splashTitleStroke, fadeOutInfo, {Transparency = 1})Play()
        TweenServiceCreate(splashSub, fadeOutInfo, {TextTransparency = 1})Play()
        TweenServiceCreate(splashSubStroke, fadeOutInfo, {Transparency = 1})Play()
        
        task.wait(1.3)
        splashGuiDestroy()
        
        -- Play user-provided ting sound when main GUI opens
        pcall(function()
            local sound = Instance.new(Sound)
            sound.Name = OpenSound
            sound.SoundId = rbxassetid9113421646 -- Sound ID chosen by the user
            sound.Volume = 1.0
            sound.Parent = screenGui
            soundPlay()
            sound.EndedConnect(function()
                soundDestroy()
            end)
        end)
        
        -- Smoothly open the main GUI with a scale-in animation
        mainFrame.Size = UDim2.new(0, 0, 0, 0)
        mainFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
        mainFrame.Visible = true
        
        local openTween = TweenServiceCreate(mainFrame, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 580, 0, 430),
            Position = UDim2.new(0.5, -290, 0.5, -215)
        })
        openTweenPlay()
    end)
    
    -- Unload function
    function WindowDestroy()
        pcall(function()
            if cursorConnection then cursorConnectionDisconnect() end
            UserInputService.MouseIconEnabled = true
            toggleConnectionDisconnect()
            screenGuiDestroy()
        end)
    end
    
    return Window
end

