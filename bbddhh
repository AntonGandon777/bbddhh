    local cursorConnection
    local function updateCursor()
        if screenGui.Enabled and mainFrame.Visible then
            UserInputService.MouseIconEnabled = true
            
            if not cursorConnection then
                cursorConnection = RunService.RenderStepped:Connect(function()
                    if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
                        -- Do nothing, let camera pan
                    else
                        if UserInputService.MouseBehavior ~= Enum.MouseBehavior.Default then
                            UserInputService.MouseBehavior = Enum.MouseBehavior.Default
                        end
                    end
                end)
            end
        else
            if cursorConnection then
                cursorConnection:Disconnect()
                cursorConnection = nil
            end
        end
    end
    
    screenGui:GetPropertyChangedSignal("Enabled"):Connect(updateCursor)
    mainFrame:GetPropertyChangedSignal("Visible"):Connect(updateCursor)
    
